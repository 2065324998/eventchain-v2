+    amount_usd = to_usd(amount, currency)
+
+    if amount_usd <= Decimal("0"):
+        return Decimal("0")
+
+    remaining_usd = amount_usd
+    total_fee = Decimal("0")
+    current_volume = cumulative_volume_usd
+
+    for threshold, rate in FEE_TIERS:
+        if remaining_usd <= Decimal("0"):
+            break
+
+        # How much USD-equivalent volume fits in this tier
+        space_in_tier = threshold - current_volume
+        if space_in_tier <= Decimal("0"):
+            continue
+
+        # Take the smaller of remaining amount and space in tier
+        portion_usd = min(remaining_usd, space_in_tier)
+
+        # Convert this USD portion back to native currency proportion
+        native_portion = amount * (portion_usd / amount_usd)
+
+        # Apply this tier's rate to the native currency portion
+        total_fee += native_portion * rate
+
+        remaining_usd -= portion_usd
+        current_volume += portion_usd
+
+    return total_fee.quantize(Decimal("0.01"), rounding=ROUND_HALF_UP)


